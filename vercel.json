{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "api/index.mjs": {
      "includeFiles": "dist/food-ecommerce/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/api"
    }
  ]
}
